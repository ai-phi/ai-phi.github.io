---
import { SITE, LOCALE } from "@config";

interface Props {
  title: string;
  eyebrow?: string;
  date?: string | Date;
  author?: string;
  description?: string;
  ogImage?: string;
  href: string;
}

const {
  title,
  eyebrow,
  date,
  author = SITE.author ?? "ai-phi",
  description,
  ogImage,
  href,
} = Astro.props as Props;

const fallbackImage = "/og/ai-phi-default-og.webp";
const resolvedImage =
  typeof ogImage === "string" && ogImage.length > 0 ? ogImage : fallbackImage;

const dateValue = date ? new Date(date) : null;
const displayDate = dateValue
  ? dateValue.toLocaleDateString(LOCALE.langTag, {
      year: "numeric",
      month: "short",
      day: "numeric",
      timeZone: LOCALE.timeZone ?? "Europe/Paris",
    })
  : "";
const displayTime = dateValue
  ? dateValue.toLocaleTimeString(LOCALE.langTag, {
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
      timeZone: LOCALE.timeZone ?? "Europe/Paris",
    })
  : "";
---

<article
  class="group relative h-full cursor-pointer rounded-2xl border border-skin-line/40 bg-[rgb(var(--color-card-muted))] p-5 shadow-lg shadow-black/10 transition-shadow transition-transform hover:-translate-y-0.5 hover:shadow-xl"
  data-card-link={href}
  tabindex="0"
  role="link"
>
  <div class="flex justify-start overflow-hidden rounded-lg bg-[rgb(var(--color-card-muted))]">
    <img
      src={resolvedImage}
      alt="Illustration"
      class="block h-auto max-h-[24rem] w-auto max-w-full rounded-lg object-contain object-left"
      loading="lazy"
      decoding="async"
    />
  </div>

  <div class="relative z-20 mt-4 flex h-full select-text flex-col">
    {
      eyebrow && (
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-skin-base opacity-80">
          {eyebrow}
        </p>
      )
    }
    <h3
      class="text-2xl font-semibold leading-tight text-skin-base transition-colors duration-150 group-hover:text-3xl"
    >
      <a
        href={href}
        class="relative z-30 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-skin-accent"
      >
        {title}
      </a>
    </h3>

    {
      dateValue && (
        <p class="mt-2 text-base font-medium text-skin-base opacity-80">
          <time datetime={dateValue.toISOString()}>{displayDate}</time>
          <span aria-hidden="true"> · </span>
          <span class="text-nowrap">{displayTime}</span>
          <span aria-hidden="true"> · </span>by {author}
        </p>
      )
    }

    {
      description && (
        <p class="mt-3 grow text-base leading-relaxed text-skin-base opacity-80 text-justify">
          {description}
        </p>
      )
    }

    <div class="mt-auto pt-4">
      <a
        href={href}
        class="inline-flex items-center gap-1 font-medium transition-all duration-150 group-hover:font-bold text-skin-base cursor-pointer"
      >
        Check details
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-150 group-hover:translate-x-0.5"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="m13 5 7 7-7 7M4 12h16"></path>
        </svg>
      </a>
    </div>
  </div>
</article>

<script is:inline>
  const isInteractiveElement = (element, card) => {
    if (!(element instanceof HTMLElement)) return false;
    const interactiveAncestor = element.closest(
      'a, button, input, textarea, select, summary, [role="button"], [role="link"]'
    );
    return !!interactiveAncestor && interactiveAncestor !== card;
  };

  const hasSelectedText = () => {
    const selection = window.getSelection();
    return !!selection && selection.toString().trim().length > 0;
  };

  const activateCard = card => {
    const href = card.dataset.cardLink;
    if (href) window.location.assign(href);
  };

  document.querySelectorAll("[data-card-link]").forEach(card => {
    if (!(card instanceof HTMLElement) || card.dataset.cardBound === "true") return;
    card.dataset.cardBound = "true";

    card.addEventListener("click", event => {
      if (hasSelectedText()) return;
      if (isInteractiveElement(event.target, card)) return;
      activateCard(card);
    });

    card.addEventListener("keydown", event => {
      if (event.key !== "Enter" && event.key !== " ") return;
      if (isInteractiveElement(event.target, card)) return;
      event.preventDefault();
      activateCard(card);
    });
  });
</script>
